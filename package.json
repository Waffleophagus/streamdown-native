{
  "name": "streamdown-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:packages": "pnpm build --filter streamdown --filter @streamdown/core --filter @streamdown/react-native --filter @streamdown/code-native --filter @streamdown/math --filter @streamdown/code --filter @streamdown/cjk --filter @streamdown/mermaid",
    "build:packages:ci": "turbo run build --filter=streamdown --filter=@streamdown/core --filter=@streamdown/react-native --filter=@streamdown/code-native --filter=@streamdown/math --filter=@streamdown/code --filter=@streamdown/cjk --filter=@streamdown/mermaid",
    "dev": "turbo run dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:ui": "turbo run test:ui",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "publish:packages": "node ./scripts/publish-packages.mjs",
    "bench": "turbo run bench",
    "bench:ui": "turbo run bench:ui",
    "bump-deps": "npx npm-check-updates -u --deep -x \"recharts\" && pnpm i"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.8.13",
    "typescript": "5.9.3",
    "ultracite": "7.2.4"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "lodash-es": ">=4.17.23",
    "react-native-reanimated": "~4.0.1",
    "react-native-worklets": "0.5.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
